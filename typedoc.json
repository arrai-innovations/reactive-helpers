{
    "entryPoints": ["config/**/*.js", "use/**/*.js", "utils/**/*.js"],
    "out": "docs",
    "excludeExternals": true,
    "excludePrivate": true,
    "excludeProtected": true,
    "plugin": ["typedoc-plugin-markdown"],
    "readme": "none",
    "disableSources": true,
    "outputFileStrategy": "modules",
    "validation": {
        "notExported": true,
        "invalidLink": true,
        "rewrittenLink": true,
        "notDocumented": false
    },
    "treatValidationWarningsAsErrors": true
}
