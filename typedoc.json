{
    "entryPoints": ["config/**/*.js", "use/**/*.js", "utils/**/*.js"],
    "out": "docs/reference",
    "excludeExternals": true,
    "excludePrivate": true,
    "excludeProtected": true,
    "excludeInternal": true,
    "plugin": ["typedoc-plugin-markdown"],
    "readme": "none",
    "disableSources": true,
    "outputFileStrategy": "modules",
    "entryFileName": "index",
    "hidePageHeader": true,
    "hideBreadcrumbs": true,
    "validation": {
        "notExported": true,
        "invalidLink": true,
        "rewrittenLink": true,
        "notDocumented": true
    },
    "requiredToBeDocumented": ["Enum", "EnumMember", "Variable", "Class", "Interface", "TypeAlias"],
    "treatValidationWarningsAsErrors": true
}
