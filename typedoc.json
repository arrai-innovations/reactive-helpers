{
    "entryPoints": ["config/**/*.js", "use/**/*.js", "utils/**/*.js"],
    "out": "docs",
    "exclude": [],
    "excludeExternals": true,
    "excludePrivate": true,
    "excludeProtected": true,
    "plugin": ["typedoc-plugin-markdown", "./typedoc-local-plugins/customize-output.js"],
    "readme": "none",
    "disableSources": true,
    "outputFileStrategy": "modules"
}
