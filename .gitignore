.DS_Store
node_modules
/dist

# vitepress docs site build output
/site

# vitepress cache/temp (lands at repo root or under docs/ depending on invocation)
**/.vitepress/cache
**/.vitepress/.temp

# per-developer vitepress dev-server overrides (see config.local.example.mjs)
docs/.vitepress/config.local.mjs

# e2e coverage
coverage
# unit coverage
.nyc_output

# Log files
pnpm-debug.log*

# vscode
.vscode/*
!.vscode/extensions.json

# eslint
.eslintcache

# Created by https://www.gitignore.io/api/intellij

### Intellij ###
# Covers JetBrains IDEs: IntelliJ, RubyMine, PhpStorm, AppCode, PyCharm, CLion, Android Studio and Webstorm
# Reference: https://intellij-support.jetbrains.com/hc/en-us/articles/206544839

# User-specific stuff:
.idea/workspace.xml
.idea/tasks.xml
.idea/dictionaries
.idea/vcs.xml
.idea/jsLibraryMappings.xml

# Sensitive or high-churn files:
.idea/dataSources.ids
.idea/dataSources.xml
.idea/dataSources.local.xml
.idea/sqlDataSources.xml
.idea/dynamic.xml
.idea/uiDesigner.xml
.idea/copilot*

# Gradle:
.idea/gradle.xml
.idea/libraries

# Mongo Explorer plugin:
.idea/mongoSettings.xml

## File-based project format:
*.iws
